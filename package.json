{
  "name": "ecom-promo-codex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:verify": "tsx scripts/verify-seed.ts",
    "mcp:promo": "tsx src/mcp/promo-campaign-mcp.ts",
    "codex:smoke": "tsx scripts/codex-smoke.ts",
    "image:smoke": "tsx scripts/image-smoke.ts",
    "integration:live": "tsx scripts/live-integration.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "better-sqlite3",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29",
    "@openai/codex-sdk": "^0.137",
    "@prisma/adapter-better-sqlite3": "^7",
    "@prisma/client": "^7",
    "next": "^16",
    "openai": "^6.42.0",
    "react": "^19",
    "react-dom": "^19",
    "zod": "^4"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.7",
    "prisma": "^7",
    "tsx": "^4.22.4",
    "typescript": "^6",
    "vitest": "^4"
  }
